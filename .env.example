# ═══════════════════════════════════════════════════════
# Max English Coach — 中国大陆版 环境变量
# ═══════════════════════════════════════════════════════

# ── DeepSeek V3 (LLM) ────────────────────────────────
# 注册: https://platform.deepseek.com → API Keys
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── 阿里云 DashScope ASR (语音识别) ─────────────────
# 注册: https://dashscope.aliyun.com → API-KEY管理
# 千问/百炼平台的 API Key，Bearer Token 鉴权
ALIYUN_DASHSCOPE_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 火山方舟 ARK TTS (语音合成) ─────────────────────
# 注册: https://console.volcengine.com/ark → API Key 管理
# 方舟平台的 API Key，Bearer Token 鉴权
VOLCANO_ARK_KEY=ark-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VOLCANO_VOICE=en_female_amanda

# ── 服务器 ───────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ── 数据库 ───────────────────────────────────────────
DATABASE_URL=sqlite:///./data/max_coach.db
CHROMA_PERSIST_DIR=./data/chroma

# ── 学习 ─────────────────────────────────────────────
CORRECTION_FREQUENCY=moderate
DEFAULT_LEARNING_MODE=free_conversation
VOICE_SPEED=1.0
VOICE_VOLUME=1.0
